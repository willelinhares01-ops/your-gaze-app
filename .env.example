# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_publica

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Chave secreta — usada SOMENTE server-side (route handlers / webhook).
# NUNCA exponha no client ou faça commit com o valor real.
STRIPE_SECRET_KEY=sk_live_...

# Chave pública — exposta ao browser (prefixo NEXT_PUBLIC_).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Segredo do webhook — gerado em dashboard.stripe.com → Webhooks → Signing secret.
# Usado para validar que o evento realmente veio do Stripe.
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Stripe Price IDs (um por tier, criados no Stripe Dashboard) ─────────────
# Crie Products com preços recorrentes (monthly) no Stripe e cole os price_xxx aqui.
STRIPE_PRICE_PREMIUM=price_premium_placeholder
STRIPE_PRICE_GOLD=price_gold_placeholder
STRIPE_PRICE_DIAMOND=price_diamond_placeholder

# ─── App ─────────────────────────────────────────────────────────────────────
# URL base do app — usada nas success_url e cancel_url do Stripe.
# Em desenvolvimento: http://localhost:3000
# Em produção: https://yourgaze.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Admin (God Mode) ────────────────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_EMAIL=admin@yourgaze.com
NEXT_PUBLIC_ADMIN_TOKEN=YOURGAZE-MASTER
